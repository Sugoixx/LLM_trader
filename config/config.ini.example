# =============================================================================
#  LLM_TRADER — Configuration (EXAMPLE / TEMPLATE)
#  Copy to config.ini and adjust to your setup.
#  Sections: ai_providers | symbol | trading | mt5 | crypto | execution_engine
#            fast_trading | safety | rag | dashboard | debug
# =============================================================================


# =============================================================================
# [ai_providers]  Provider selection + model parameters
# =============================================================================
[ai_providers]
# Options: "local" | "googleai" | "openrouter" | "blockrun" | "all"
provider = googleai

# Priority order when provider = "all": first provider to respond wins.
# "local" costs nothing — put it first to avoid burning API credits.
# Chart requests skip "local" automatically (no vision support).
all_provider_order = local,googleai,openrouter,blockrun

# ---------- LM Studio (local) ------------------------------------------------
lm_studio_base_url = http://localhost:1234/v1
lm_studio_model =
lm_studio_streaming = false

# ---------- OpenRouter -------------------------------------------------------
openrouter_base_url = https://openrouter.ai/api/v1
openrouter_base_model = google/gemini-3-flash-preview
openrouter_fallback_model = deepseek/deepseek-r1:free

# ---------- Google AI Studio -------------------------------------------------
google_studio_model = gemini-3-flash-preview

# ---------- BlockRun.AI ------------------------------------------------------
blockrun_base_url = https://blockrun.ai/api
blockrun_model = deepseek/deepseek-reasoner

# ---------- Model parameters (default) --------------------------------------
temperature = 0.7
top_p = 0.9
top_k = 40
max_tokens = 32768
#freq_penalty = 0.1
#pres_penalty = 0.1

# ---------- Google-specific overrides ----------------------------------------
google_temperature = 1.0
google_top_p = 0.95
google_top_k = 64
google_max_tokens = 32768
google_thinking_level = high
google_code_execution = false


# =============================================================================
# [symbol]  Active trading instrument
# =============================================================================
[symbol]
# Crypto  : BTC/USDT  BTC/USDC  ETH/USDT
# Forex   : EURUSD  GBPUSD  USDJPY
# Metals  : XAUUSD (Gold)  XAGUSD (Silver)
# Oil     : XTIUSD (WTI)  XBRUSD (Brent)  XNGUSD (Natural Gas)
crypto_pair = BTC/USDC
# Valid: 1m 3m 5m 15m 30m 1h 2h 4h 6h 8h 12h 1d 1w
timeframe = 4h
candle_limit = 999
ai_chart_candle_limit = 125


# =============================================================================
# [trading]  General behaviour, live on/off, demo capital, backtest, debate
# =============================================================================
[trading]
# 0 = call LLM every candle close. Guide: 1m→5 | 5m→5 | 15m→15 | 30m→0 | 1h+→0
analysis_cooldown_minutes = 0
discord_bot = true
include_coin_description = false

# ---- Live trading -----------------------------------------------------------
# DANGER: true = real orders with real money
enabled = false
order_type = limit

# ---- Demo / paper trading ---------------------------------------------------
demo_quote_capital = 10000
transaction_fee_percent = 0.00075

# ---- Backtesting ------------------------------------------------------------
initial_capital = 10000

# ---- Bull/Bear debate -------------------------------------------------------
debate_enabled = false
debate_use_quick_model = true
debate_skip_for_hold = true


# =============================================================================
# [mt5]  MetaTrader 5 — Forex / Commodities / Indices
# =============================================================================
[mt5]
# true = use MT5 terminal instead of CCXT (Windows only)
enabled = false
# terminal_path = C:\Program Files\MetaTrader 5\terminal64.exe
skip_llm_when_market_closed = true
preopen_analysis_minutes = 20
market_stale_tick_seconds = 1800


# =============================================================================
# [crypto]  CCXT crypto exchanges (used when mt5.enabled = false)
# =============================================================================
[crypto]
exchange = binance
# testnet = true for Binance Spot DEMO (demo-api.binance.com — separate keys)
testnet = false
supported = binance,kucoin,gateio,mexc,hyperliquid
market_refresh_hours = 24


# =============================================================================
# [execution_engine]  Layer 2 — real-time SL/TP/trailing via WebSocket
# =============================================================================
[execution_engine]
enabled = true
trailing_enabled = true
trailing_atr_multiplier = 2.0
trailing_atr_multiplier_after_tp1 = 0.5
trailing_breakeven_on_tp1 = true
partial_enabled = false
partial_targets = 0.5:0.5, 1.0:1.0


# =============================================================================
# [fast_trading]  Algo-only fast mode — LLM acts as correction layer only
# =============================================================================
[fast_trading]
min_interval_seconds = 900
daily_loss_pct_limit = -3.0
consecutive_loss_threshold = 3
consecutive_loss_cooldown_seconds = 7200
poll_interval_seconds = 300
block_minutes_before_close = 15
allow_gap_trading = false


# =============================================================================
# [safety]  AI safety gates + live order caps + cooldowns
# =============================================================================
[safety]
# ---- AI entry gates ---------------------------------------------------------
min_confidence = MEDIUM
consecutive_loss_threshold = 3
consecutive_loss_cooldown_minutes = 60
min_rr_after_fees = 1.2

# ---- Live order size caps ---------------------------------------------------
max_order_usd = 500
max_order_usd_ai = 500
max_order_usd_fast = 200
double_trade_enabled = false
max_min_lot_margin_pct = 0.10
confirm_orders = true

# ---- Cooldowns --------------------------------------------------------------
file_message_expiry = 168


# =============================================================================
# [rag]  News / data feeds
# =============================================================================
[rag]
update_interval_hours = 4
categories_update_interval_hours = 168
coingecko_update_interval_hours = 24
defillama_update_interval_hours = 0.25
coingecko_global_api_url = https://api.coingecko.com/api/v3/global
news_limit = 5
article_max_tokens = 500
news_filter_sources = true
# Crypto defaults : cointelegraph,coindesk,theblock,decrypt,bitcoinmagazine
# MT5/macro       : seekingalpha,invezz,coinpaper,cryptopotato
news_allowed_feeds = cointelegraph,coindesk,theblock,decrypt,bitcoinmagazine


# =============================================================================
# [dashboard]  Web dashboard
# =============================================================================
[dashboard]
enabled = true
# 127.0.0.1 = local only (recommended) | 0.0.0.0 = LAN access
host = 0.0.0.0
port = 8000
enable_cors = false
cors_origins = *


# =============================================================================
# [debug]  Logging, storage directories, chart debugging
# =============================================================================
[debug]
save_chart_images = false
chart_save_path = chart_images
logger_debug = true
log_dir = logs
data_dir = data
